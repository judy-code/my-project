# Google OAuth Client ID，於 https://console.cloud.google.com/apis/credentials 建立
# 「OAuth 用戶端 ID」（應用程式類型選「網頁應用程式」），並在「已授權的 JavaScript 來源」
# 加入 http://localhost:5173（開發環境）與正式上線網域。
# 複製此檔為 .env 並貼上取得的 Client ID。
VITE_GOOGLE_CLIENT_ID=

# ---- 後端 (server/) 使用，帳號密碼登入 + MySQL/phpMyAdmin ----
# 對應你在 XAMPP/WAMP/Laragon 裡的 MySQL 帳密（預設帳號通常是 root、密碼空白）
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=cotrace
# 用來簽發登入用的 JWT，改成你自己的隨機長字串即可（不要用範例值）
JWT_SECRET=請改成一組隨機長字串
PORT=4000
CLIENT_ORIGIN=http://localhost:5173
